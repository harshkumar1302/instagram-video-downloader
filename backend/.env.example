# Flask runtime
PORT=5000
FLASK_DEBUG=0

# Instagram authentication strategy
# `none` (default): URL-only mode (public content only)
# `browser`: use browser cookies via COOKIE_BROWSER
# `file`: use backend/cookies.txt
# `auto`: backend/cookies.txt if present, else browser cookies
INSTAGRAB_AUTH_MODE=none
COOKIE_BROWSER=chrome

# Downloader behavior
INFO_TIMEOUT_SECONDS=30
DOWNLOAD_TIMEOUT_SECONDS=120
DOWNLOAD_TTL_SECONDS=3600
IMAGE_FETCH_TIMEOUT_SECONDS=8
IMAGE_CANDIDATE_LIMIT=6

# Set to 1 to disable MP3 conversion endpoint (recommended for serverless deployments).
DISABLE_MP3=0

# Optional explicit FFmpeg directory (contains ffmpeg + ffprobe binaries)
# Example: /opt/homebrew/bin
FFMPEG_LOCATION=
